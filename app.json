{
  "expo": {
    "name": "Graider",
    "slug": "graider-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "graidermobile",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#fdfaf1"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.davidtapestry.graider-mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Graider needs camera access to photograph handwritten paper stacks for grading.",
        "NSPhotoLibraryUsageDescription": "Graider needs photo library access to upload stack photos for grading."
      }
    },
    "android": {
      "package": "com.davidtapestry.graider_mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#fdfaf1"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "updates": {
      "url": "https://u.expo.dev/b70af95c-f07a-4300-9d13-8e6743bbead8",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-updates",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#1a4fd0"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#fdfaf1",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 168,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Graider needs photo library access to upload stack photos for grading.",
          "cameraPermission": "Graider needs camera access to photograph handwritten paper stacks for grading."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b70af95c-f07a-4300-9d13-8e6743bbead8"
      }
    },
    "owner": "ogdavidly"
  }
}
