# Graider Mobile — environment variables
# Copy to .env and fill in values. Never commit .env.

# Backend API (Next.js on Vercel)
EXPO_PUBLIC_APP_URL=https://graider.vercel.app

# Clerk (use pk_test_ for local dev, pk_live_ on EAS production)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# RevenueCat (public SDK keys from RevenueCat dashboard)
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
