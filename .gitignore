# Learn more: https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# Dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native project folders (regenerated by `expo prebuild` / EAS Build; omit these lines if you commit a bare workflow)
/ios
/android

# Kotlin
.kotlin/

# Metro
.metro-health-check*

# Logs & debug
npm-debug.*
yarn-debug.*
yarn-error.*
*.log
lerna-debug.log*
.pnpm-debug.log*

# macOS
.DS_Store
*.pem
*.pem

# Environment & secrets (keep `.env.example` tracked if you use one)
.env
.env.*
!.env.example
!.env*.example

# local IDE / agent state (may contain API keys)
.cursor/
.claude/

# TypeScript
*.tsbuildinfo

# Testing & coverage
coverage/
.nyc_output/

# IDEs
.idea/
*.swp
*.swo
*~

# Xcode (if you ever track `ios/` locally)
**/ios/**/*.xcworkspace/xcuserdata/
**/ios/**/*.xcodeproj/xcuserdata/
**/ios/**/*.xcodeproj/project.xcworkspace/xcuserdata/
**/ios/**/DerivedData/
**/ios/**/*.hmap
**/ios/**/ipa/
*.xcuserstate
**/ios/.xcode.env.local

# Android (if you ever track `android/` locally)
**/android/.gradle/
**/android/build/
**/android/app/build/
**/android/local.properties
**/android/.cxx/
**/android/*.hprof
**/android/captures/
**/android/.externalNativeBuild/

# Ruby / CocoaPods (bare workflow)
**/ios/Pods/

# Fastlane
**/fastlane/report.xml
**/fastlane/Preview.html
**/fastlane/screenshots/**/*.png
**/fastlane/test_output

# Bundles
*.jsbundle

# EAS / local credentials (never commit)
credentials.json
*.p12
*.p8
*.key
*.mobileprovision
*.orig.*
*.jks
*.keystore
!debug.keystore

# Optional: Firebase / Google config — remove these lines if your team commits them intentionally
# google-services.json
# GoogleService-Info.plist
